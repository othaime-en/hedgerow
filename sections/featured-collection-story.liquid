{% liquid
  assign collection = section.settings.collection
  assign heading = section.settings.heading
  if heading == blank and collection != blank
    assign heading = collection.title
  endif

  assign story = section.settings.story
  if story == blank and collection != blank and collection.metafields.custom.collection_story != blank
    assign story = collection.metafields.custom.collection_story.value
  endif

  assign image = section.settings.image
  if image == blank and collection != blank
    assign image = collection.featured_image
  endif

  assign cta_link = section.settings.cta_link
  if cta_link == blank and collection != blank
    assign cta_link = collection.url
  endif
%}

<div
  class="featured-story full-width section-padding"
  style="{% render 'section-padding', section: section %}"
>
  <div class="featured-story__inner container featured-story--{{ section.settings.image_position }}">
    <div class="featured-story__media">
      {% if image != blank %}
        {{
          image
          | image_url: width: 1400
          | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 50vw, 100vw', widths: '500, 800, 1100, 1400'
        }}
      {% else %}
        <div class="featured-story__placeholder"></div>
      {% endif %}
    </div>

    <div class="featured-story__content">
      {% if section.settings.eyebrow != blank %}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if heading != blank %}
        <h2 class="text-2xl">{{ heading }}</h2>
      {% endif %}
      {% if story != blank %}
        <p class="text-lg featured-story__story">{{ story }}</p>
      {% endif %}
      {% if section.settings.cta_text != blank %}
        <a href="{{ cta_link | default: '#' }}" class="button button--primary featured-story__cta">
          {{ section.settings.cta_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .featured-story__inner {
    display: grid;
    gap: var(--space-6);
    align-items: center;
  }

  .featured-story__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }
  .featured-story__placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
  }

  .featured-story__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .featured-story__story {
    color: var(--color-ink-muted);
    max-width: 42ch;
  }
  .featured-story__cta {
    width: auto;
    padding-inline: var(--space-5);
    margin-top: var(--space-2);
  }

  @media (min-width: 750px) {
    .featured-story__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
    .featured-story--right .featured-story__media {
      order: 2;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.featured_collection_story",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:labels.collection",
      "info": "t:info.featured_story_collection"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image",
      "info": "t:info.featured_story_image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:labels.image_position",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:general.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Featured collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "info": "t:info.featured_story_heading"
    },
    {
      "type": "textarea",
      "id": "story",
      "label": "t:labels.story",
      "info": "t:info.featured_story_story"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:labels.cta_text",
      "default": "Shop the collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:labels.cta_link",
      "info": "t:info.featured_story_cta_link"
    },
    {
      "type": "header",
      "content": "t:general.spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    }
  ],
  "presets": [{ "name": "t:general.featured_collection_story" }]
}
{% endschema %}
