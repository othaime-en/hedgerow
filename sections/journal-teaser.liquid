{% liquid
  assign blog = section.settings.blog | default: blogs.news
%}

<div
  class="journal-teaser full-width section-padding"
  style="{% render 'section-padding', section: section %}"
>
  <div class="container">
    <div class="journal-teaser__inner">
      <div class="journal-teaser__header">
        {% if section.settings.eyebrow != blank %}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="text-2xl">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
      {% if blog != blank and section.settings.view_all_text != blank %}
        <a href="{{ blog.url }}" class="journal-teaser__view-all text-sm">{{ section.settings.view_all_text }}</a>
      {% endif %}
    </div>

    {% if blog != blank and blog.articles.size > 0 %}
      <div class="journal-teaser__grid">
        {% for article in blog.articles limit: 3 %}
          <a href="{{ article.url }}" class="journal-teaser__card card">
            <div class="journal-teaser__media">
              {% if article.image %}
                {{
                  article.image
                  | image_url: width: 800
                  | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 33vw, 100vw', widths: '400, 600, 800'
                }}
              {% else %}
                <div class="journal-teaser__placeholder"></div>
              {% endif %}
            </div>
            <div class="card__body">
              {% if article.tags.size > 0 %}
                <span class="eyebrow">{{ article.tags.first }}</span>
              {% endif %}
              <h3 class="text-lg">{{ article.title }}</h3>
              {% if article.excerpt != blank %}
                <p class="journal-teaser__excerpt text-sm">{{ article.excerpt | strip_html | truncate: 90 }}</p>
              {% else %}
                <p class="journal-teaser__excerpt text-sm">{{ article.content | strip_html | truncate: 90 }}</p>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      </div>
    {% elsif request.design_mode %}
      <div class="journal-teaser__empty-state">
        <p class="text-base">{{ 'journal_teaser.empty_state' | t }}</p>
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .journal-teaser__inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
  }
  .journal-teaser__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .journal-teaser__view-all {
    flex-shrink: 0;
    color: var(--color-ink-muted);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  .journal-teaser__view-all:hover {
    color: var(--color-clay);
  }

  .journal-teaser__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .journal-teaser__card {
    text-decoration: none;
    color: var(--color-ink);
  }
  .journal-teaser__media {
    aspect-ratio: 4 / 3;
    background-color: var(--color-surface);
  }
  .journal-teaser__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .journal-teaser__placeholder {
    width: 100%;
    height: 100%;
  }
  .journal-teaser__excerpt {
    color: var(--color-ink-muted);
  }

  .journal-teaser__empty-state {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 8rem;
    background-color: var(--color-surface);
    color: var(--color-ink-muted);
    border-radius: var(--radius-md);
  }

  @media (min-width: 750px) {
    .journal-teaser__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-5);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.journal_teaser",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "t:labels.blog",
      "info": "t:info.journal_teaser_blog"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "The journal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Notes on living well"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "t:labels.view_all",
      "default": "Read the journal"
    },
    {
      "type": "header",
      "content": "t:general.spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    }
  ],
  "presets": [{ "name": "t:general.journal_teaser" }]
}
{% endschema %}
