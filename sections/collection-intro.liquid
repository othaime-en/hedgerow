{% liquid
  assign story = section.settings.story
  if story == blank and collection.metafields.custom.collection_story != blank
    assign story = collection.metafields.custom.collection_story.value
  elsif story == blank
    assign story = collection.description
  endif

  assign image = section.settings.image
  if image == blank
    assign image = collection.image
  endif
%}

{% if story != blank or image != blank or section.settings.heading != blank %}
  <div class="collection-intro full-width section-padding" style="{% render 'section-padding', section: section %}">
    <div class="collection-intro__inner container">
      {% if image != blank %}
        <div class="collection-intro__media">
          {{
            image
            | image_url: width: 1400
            | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 40vw, 100vw', widths: '500, 800, 1100, 1400'
          }}
        </div>
      {% endif %}

      <div class="collection-intro__content">
        {% if section.settings.eyebrow != blank %}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="text-2xl">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if story != blank %}
          <div class="collection-intro__story text-lg">{{ story | strip_html | truncatewords: 60 }}</div>
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .collection-intro__inner {
    display: grid;
    gap: var(--space-6);
    align-items: center;
  }
  .collection-intro__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }
  .collection-intro__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .collection-intro__story {
    color: var(--color-ink-muted);
    max-width: 48ch;
  }
  @media (min-width: 750px) {
    .collection-intro__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection_intro",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image",
      "info": "t:info.collection_intro_image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "info": "t:info.collection_intro_heading"
    },
    {
      "type": "textarea",
      "id": "story",
      "label": "t:labels.story",
      "info": "t:info.collection_intro_story"
    },
    {
      "type": "header",
      "content": "t:general.spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ]
}
{% endschema %}
