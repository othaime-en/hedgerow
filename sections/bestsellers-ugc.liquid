<div
  class="bestsellers-ugc full-width section-padding"
  style="{% render 'section-padding', section: section %}"
>
  <div class="container">
    {% if section.settings.eyebrow != blank or section.settings.heading != blank %}
      <div class="bestsellers-ugc__header">
        {% if section.settings.eyebrow != blank %}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="text-2xl">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="bestsellers-ugc__grid">
        {% content_for 'blocks' %}
      </div>
    {% elsif request.design_mode %}
      <div class="bestsellers-ugc__empty-state">
        <p class="text-base">{{ 'bestsellers_ugc.empty_state' | t }}</p>
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .bestsellers-ugc__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .bestsellers-ugc__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .bestsellers-ugc__empty-state {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 12rem;
    background-color: var(--color-surface);
    color: var(--color-ink-muted);
    border-radius: var(--radius-md);
  }

  @media (min-width: 750px) {
    .bestsellers-ugc__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-5);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.bestsellers_ugc",
  "blocks": [{ "type": "ugc-review" }],
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "As seen at home"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Loved in real rooms"
    },
    {
      "type": "header",
      "content": "t:general.spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "t:general.bestsellers_ugc",
      "blocks": [{ "type": "ugc-review" }, { "type": "ugc-review" }, { "type": "ugc-review" }, { "type": "ugc-review" }]
    }
  ]
}
{% endschema %}
