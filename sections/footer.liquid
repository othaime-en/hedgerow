{% doc %}
  Site footer: three link columns (shop/company/help), social icons,
  an editorial newsletter signup, and payment icons (small, muted,
  bottom-most).

  Note: Phase 3 of the implementation plan also defines a standalone
  sections/newsletter.liquid positioned just above the footer. Having
  both on the same page asks for an email twice in a row — see the
  Phase 2 summary for the flagged conflict. This footer signup is
  built to stand alone (useful on templates that don't include the
  Phase 3 section, like the cart page), not to be redundant with it.
{% enddoc %}

<footer class="footer full-width">
  <div class="footer__top">
    <div class="footer__brand">
      <a class="footer__logo text-lg" href="{{ routes.root_url }}">{{ shop.name }}</a>
      {% if section.settings.tagline != blank %}
        <p class="footer__tagline text-sm">{{ section.settings.tagline }}</p>
      {% endif %}

      {% if section.settings.social_instagram != blank or section.settings.social_pinterest != blank or section.settings.social_facebook != blank %}
        <div class="footer__socials">
          {% if section.settings.social_instagram != blank %}
            <a href="{{ section.settings.social_instagram }}" aria-label="Instagram">{{ 'icon-instagram.svg' | inline_asset_content }}</a>
          {% endif %}
          {% if section.settings.social_pinterest != blank %}
            <a href="{{ section.settings.social_pinterest }}" aria-label="Pinterest">{{ 'icon-pinterest.svg' | inline_asset_content }}</a>
          {% endif %}
          {% if section.settings.social_facebook != blank %}
            <a href="{{ section.settings.social_facebook }}" aria-label="Facebook">{{ 'icon-facebook.svg' | inline_asset_content }}</a>
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% if section.settings.shop_menu != blank %}
      <div class="footer__column">
        <span class="eyebrow">{{ section.settings.shop_menu_heading }}</span>
        <ul role="list">
          {% for link in section.settings.shop_menu.links %}
            <li><a href="{{ link.url }}" class="text-sm">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    {% if section.settings.company_menu != blank %}
      <div class="footer__column">
        <span class="eyebrow">{{ section.settings.company_menu_heading }}</span>
        <ul role="list">
          {% for link in section.settings.company_menu.links %}
            <li><a href="{{ link.url }}" class="text-sm">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    {% if section.settings.help_menu != blank %}
      <div class="footer__column">
        <span class="eyebrow">{{ section.settings.help_menu_heading }}</span>
        <ul role="list">
          {% for link in section.settings.help_menu.links %}
            <li><a href="{{ link.url }}" class="text-sm">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    <div class="footer__newsletter">
      <span class="eyebrow">{{ section.settings.newsletter_heading }}</span>
      {% if section.settings.newsletter_subtext != blank %}
        <p class="text-sm">{{ section.settings.newsletter_subtext }}</p>
      {% endif %}

      {% form 'customer', class: 'footer__newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {% if form.posted_successfully? %}
          <p class="footer__newsletter-message text-sm">{{ 'newsletter.success' | t }}</p>
        {% else %}
          <div class="footer__newsletter-field">
            <input
              type="email"
              name="contact[email]"
              class="text-sm"
              placeholder="{{ 'newsletter.placeholder' | t }}"
              required
            >
            <button type="submit" class="footer__newsletter-submit" aria-label="{{ 'newsletter.submit' | t }}">
              {{ 'icon-chevron-down.svg' | inline_asset_content }}
            </button>
          </div>
          {% if form.errors %}
            <p class="footer__newsletter-error text-sm">{{ form.errors.messages.email }}</p>
          {% endif %}
        {% endif %}
      {% endform %}
    </div>
  </div>

  <div class="footer__bottom">
    <p class="footer__copyright text-xs">
      &copy;
      {{ 'now' | date: '%Y' }}
      {{ shop.name | link_to: routes.root_url }}, {{ powered_by_link }}
    </p>

    {% if section.settings.show_payment_icons %}
      <div class="footer__payment">
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag }}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</footer>

{% stylesheet %}
  .footer {
    padding: var(--space-8) var(--page-margin) var(--space-5);
    background-color: var(--color-surface);
  }

  .footer__top {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    max-width: var(--page-width);
    margin-inline: auto;
    padding-bottom: var(--space-6);
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    grid-column: 1 / -1;
  }
  .footer__logo {
    font-family: var(--font-display);
    color: var(--color-ink);
    text-decoration: none;
  }
  .footer__tagline {
    color: var(--color-ink-muted);
    max-width: 24rem;
  }
  .footer__socials {
    display: flex;
    gap: var(--space-3);
  }
  .footer__socials svg {
    width: 1.1rem;
    height: 1.1rem;
    color: var(--color-ink);
  }

  .footer__column ul {
    list-style: none;
    padding: 0;
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .footer__column a {
    color: var(--color-ink-muted);
    text-decoration: none;
  }
  .footer__column a:hover {
    color: var(--color-ink);
  }

  .footer__newsletter {
    grid-column: 1 / -1;
  }
  .footer__newsletter p {
    color: var(--color-ink-muted);
    margin-top: var(--space-2);
    max-width: 24rem;
  }
  .footer__newsletter-field {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    max-width: 22rem;
    border-bottom: 1px solid var(--color-ink);
    padding-bottom: var(--space-2);
  }
  .footer__newsletter-field input {
    flex: 1;
    border: none;
    background: none;
    outline: none;
    color: var(--color-ink);
  }
  .footer__newsletter-submit {
    display: flex;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-ink);
  }
  .footer__newsletter-submit svg {
    width: 0.85rem;
    height: 0.85rem;
    transform: rotate(-90deg);
  }
  .footer__newsletter-error {
    color: var(--color-clay-dark);
    margin-top: var(--space-2);
  }

  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    max-width: var(--page-width);
    margin-inline: auto;
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-sand);
  }
  .footer__copyright {
    color: var(--color-ink-muted);
  }
  .footer__payment {
    display: flex;
    gap: var(--space-2);
    opacity: 0.6;
  }
  .footer__payment svg {
    height: 1.25rem;
    width: auto;
  }

  @media (min-width: 750px) {
    .footer__top {
      grid-template-columns: 1.5fr repeat(3, 1fr);
    }
    .footer__brand {
      grid-column: auto;
    }
    .footer__newsletter {
      grid-column: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "t:labels.tagline"
    },
    {
      "type": "header",
      "content": "t:general.footer_columns"
    },
    {
      "type": "text",
      "id": "shop_menu_heading",
      "label": "t:labels.column_heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "company_menu_heading",
      "label": "t:labels.column_heading",
      "default": "Company"
    },
    {
      "type": "link_list",
      "id": "company_menu",
      "label": "t:labels.menu"
    },
    {
      "type": "text",
      "id": "help_menu_heading",
      "label": "t:labels.column_heading",
      "default": "Help"
    },
    {
      "type": "link_list",
      "id": "help_menu",
      "label": "t:labels.menu"
    },
    {
      "type": "header",
      "content": "t:general.newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "t:labels.heading",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "t:labels.subtext",
      "default": "New patterns, restocks, and the occasional good excuse to redecorate."
    },
    {
      "type": "header",
      "content": "t:general.social"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "t:labels.instagram"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "t:labels.pinterest"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "t:labels.facebook"
    },
    {
      "type": "header",
      "content": "t:general.payment"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
