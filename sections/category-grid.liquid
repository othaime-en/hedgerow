<div
  class="category-grid category-grid--{{ section.settings.background }} full-width section-padding"
  style="{% render 'section-padding', section: section %}"
>
  <div class="category-grid__inner container">
    {% if section.settings.eyebrow != blank or section.settings.heading != blank %}
      <div class="category-grid__header">
        {% if section.settings.eyebrow != blank %}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="text-2xl">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="grid-12 category-grid__grid">
        {% content_for 'blocks' %}
      </div>
    {% elsif request.design_mode %}
      <div class="category-grid__empty-state">
        <p class="text-base">{{ 'category_grid.empty_state' | t }}</p>
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .category-grid--bg {
    background-color: var(--color-bg);
  }
  .category-grid--surface {
    background-color: var(--color-surface);
  }

  .category-grid__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .category-grid__grid {
    row-gap: var(--space-4);
  }

  .category-grid__empty-state {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 12rem;
    background-color: var(--color-surface);
    color: var(--color-ink-muted);
    border-radius: var(--radius-md);
  }

  @media (min-width: 750px) {
    .category-grid__grid {
      row-gap: var(--space-5);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.category_grid",
  "blocks": [{ "type": "category-tile" }],
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Shop by room"
    },
    {
      "type": "select",
      "id": "background",
      "label": "t:labels.background",
      "options": [
        { "value": "bg", "label": "t:options.background_style.bg" },
        { "value": "surface", "label": "t:options.background_style.surface" }
      ],
      "default": "bg"
    },
    {
      "type": "header",
      "content": "t:general.spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "t:general.category_grid",
      "blocks": [
        { "type": "category-tile" },
        { "type": "category-tile" },
        { "type": "category-tile" },
        { "type": "category-tile" }
      ]
    }
  ]
}
{% endschema %}
