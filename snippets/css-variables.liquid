{% doc %}
  Emits the CSS custom properties that come from merchant-editable
  Theme Editor settings: the brand color palette and the two font
  picks (display/heading + body). Everything else (spacing, radius,
  shadow, motion, type scale, grid) is fixed and lives in
  assets/base.css instead — see docs/BRAND_BRIEF.md for why colors
  and fonts are the only tokens exposed to merchants.

  @example
  {% render 'css-variables' %}
{% enddoc %}
{% style %}
  {% # Loads all font variations with display: swap, for both brand fonts %}
  {{ settings.type_header_font | font_face: font_display: 'swap' }}
  {{ settings.type_header_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_header_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  {{ settings.type_body_font | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'weight', 'bold' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  :root {
    /* Typography — family comes from the merchant's font_picker choice;
       fallback_families is supplied by Shopify's font object and
       adapts automatically to whatever font is selected (serif/sans),
       so we don't hardcode a static fallback stack here. */
    --font-display: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    --font-display--style: {{ settings.type_header_font.style }};
    --font-display--weight: {{ settings.type_header_font.weight }};

    --font-body: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    --font-body--style: {{ settings.type_body_font.style }};
    --font-body--weight: {{ settings.type_body_font.weight }};

    /* Color palette — "Soft Warm" system, BRAND_BRIEF.md §2 */
    --color-bg: {{ settings.color_bg }};
    --color-surface: {{ settings.color_surface }};
    --color-ink: {{ settings.color_ink }};
    --color-ink-muted: {{ settings.color_ink_muted }};
    --color-clay: {{ settings.color_clay }};
    --color-clay-dark: {{ settings.color_clay_dark }};
    --color-blush: {{ settings.color_blush }};
    --color-sage: {{ settings.color_sage }};
    --color-sand: {{ settings.color_sand }};
    --color-white: {{ settings.color_white }};
  }
{% endstyle %}
