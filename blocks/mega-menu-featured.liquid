{% doc %}
  Renders a single featured-image tile inside a mega-menu panel — used to
  spotlight a new collection or pattern alongside the plain-link columns.

  @example
  {% content_for 'block', type: 'mega-menu-featured', id: 'featured' %}
{% enddoc %}

<a
  class="mega-menu-featured media-caption"
  href="{{ block.settings.url | default: '#' }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.image %}
    {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', sizes: '240px' }}
  {% else %}
    <div class="mega-menu-featured__placeholder"></div>
  {% endif %}
  {% if block.settings.heading != blank %}
    <span class="media-caption__label text-lg">{{ block.settings.heading }}</span>
  {% endif %}
</a>

{% stylesheet %}
  .mega-menu-featured {
    display: block;
    width: 15rem;
    aspect-ratio: 4 / 5;
  }
  .mega-menu-featured img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .mega-menu-featured__placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--color-surface);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.mega_menu_featured",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "url",
      "id": "url",
      "label": "t:labels.link"
    }
  ],
  "presets": [{ "name": "t:general.mega_menu_featured" }]
}
{% endschema %}
