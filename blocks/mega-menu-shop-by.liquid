{% doc %}
  Renders a "shop by pattern" or "shop by room" sub-list inside a
  mega-menu panel — a second, cross-cutting way into the catalog
  alongside the plain category link columns (BRAND_BRIEF.md IA note).

  Sourced from a merchant-picked collection list rather than the
  custom.pattern_name / custom.room metafields, since those aren't set
  up in Admin yet (the implementation plan schedules that "before
  Phase 3"). Swap this to a metafield-driven list once they exist, if
  you'd rather not maintain the collection list by hand.

  @example
  {% content_for 'block', type: 'mega-menu-shop-by', id: 'shop-by' %}
{% enddoc %}

{% if block.settings.collections != blank %}
  <div class="mega-menu-shop-by" {{ block.shopify_attributes }}>
    {% if block.settings.heading != blank %}
      <span class="eyebrow">{{ block.settings.heading }}</span>
    {% endif %}
    <ul class="mega-menu-shop-by__list" role="list">
      {% for collection in block.settings.collections %}
        <li>
          <a class="mega-menu-shop-by__item" href="{{ collection.url }}">
            <span class="mega-menu-shop-by__swatch">
              {% if collection.featured_image %}
                {{ collection.featured_image | image_url: width: 80 | image_tag: loading: 'lazy', sizes: '32px' }}
              {% endif %}
            </span>
            <span class="text-sm">{{ collection.title }}</span>
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
{% endif %}

{% stylesheet %}
  .mega-menu-shop-by {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .mega-menu-shop-by__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
  }
  .mega-menu-shop-by__item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-ink);
    text-decoration: none;
  }
  .mega-menu-shop-by__item:hover {
    color: var(--color-clay);
  }
  .mega-menu-shop-by__swatch {
    display: block;
    overflow: hidden;
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-sm);
    background-color: var(--color-surface);
  }
  .mega-menu-shop-by__swatch img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.mega_menu_shop_by",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.column_heading",
      "default": "Shop by pattern"
    },
    {
      "type": "collection_list",
      "id": "collections",
      "label": "t:labels.collections",
      "limit": 6
    }
  ],
  "presets": [{ "name": "t:general.mega_menu_shop_by" }]
}
{% endschema %}
